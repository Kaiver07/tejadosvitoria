---
import { site } from '../config/site.config';

interface Props {
  title?: string;
  subtitle?: string;
}
const {
  title = 'Solicita tu Presupuesto Gratuito',
  subtitle = 'Sin compromiso. Te respondemos en menos de 24 horas.',
} = Astro.props;
---

<div id="contacto" class="bg-brand-primary rounded-2xl p-8 lg:p-10 text-white">
  <h2 class="text-2xl lg:text-3xl font-bold mb-2">{title}</h2>
  <p class="text-gray-300 mb-6">{subtitle}</p>

  <form
    id="contact-form"
    action="https://api.web3forms.com/submit"
    method="POST"
    class="space-y-4"
    novalidate
    data-phone-display={site.phoneDisplay}
  >
    <input type="hidden" name="access_key" value={site.formAccessKey} />
    <input type="hidden" name="subject" value={`Nuevo presupuesto - ${site.name}`} />
    <input type="hidden" name="from_name" value={site.name} />
    <!-- Honeypot anti-spam -->
    <input type="checkbox" name="botcheck" class="hidden" aria-hidden="true" />

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label for="cf-name" class="block text-sm font-medium text-gray-300 mb-1">Nombre *</label>
        <input
          type="text"
          id="cf-name"
          name="name"
          required
          placeholder="Tu nombre"
          class="w-full bg-white/10 border border-white/30 rounded-lg px-4 py-3 text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-accent focus:border-transparent"
        />
      </div>
      <div>
        <label for="cf-phone" class="block text-sm font-medium text-gray-300 mb-1">Teléfono *</label>
        <input
          type="tel"
          id="cf-phone"
          name="phone"
          required
          placeholder="6XX XXX XXX"
          class="w-full bg-white/10 border border-white/30 rounded-lg px-4 py-3 text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-accent focus:border-transparent"
        />
      </div>
    </div>

    <div>
      <label for="cf-email" class="block text-sm font-medium text-gray-300 mb-1">Email</label>
      <input
        type="email"
        id="cf-email"
        name="email"
        placeholder="tu@email.com"
        class="w-full bg-white/10 border border-white/30 rounded-lg px-4 py-3 text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-accent focus:border-transparent"
      />
    </div>

    <div>
      <label for="cf-message" class="block text-sm font-medium text-gray-300 mb-1">Describe el trabajo *</label>
      <textarea
        id="cf-message"
        name="message"
        required
        rows="4"
        placeholder="Ej: Tengo una gotera en el tejado del salón, la casa es de 1980 y el tejado no se ha tocado..."
        class="w-full bg-white/10 border border-white/30 rounded-lg px-4 py-3 text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-accent focus:border-transparent resize-none"
      ></textarea>
    </div>

    <button
      id="cf-submit"
      type="submit"
      class="w-full btn-cta py-4 text-base font-bold disabled:opacity-60 disabled:cursor-not-allowed"
    >
      Enviar solicitud de presupuesto
    </button>

    <p id="cf-status" class="text-sm text-center hidden" role="status" aria-live="polite"></p>

    <p class="text-xs text-gray-400 text-center">
      Al enviar este formulario aceptas nuestra
      <a href="/politica-de-privacidad/" class="underline hover:text-white">Política de Privacidad</a>.
      Tus datos no serán cedidos a terceros.
    </p>
  </form>
</div>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('cf-submit') as HTMLButtonElement | null;
  const status = document.getElementById('cf-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submitBtn || !status) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Enviando...';
    status.classList.add('hidden');

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });
      const data = await res.json();

      if (data.success) {
        window.vaTrack?.('form_submit');
        form.reset();
        form.classList.add('hidden');
        status.textContent = '✅ ¡Gracias! Hemos recibido tu solicitud, te contactaremos en menos de 24 horas.';
        status.className = 'text-sm text-center text-green-400 font-semibold';
      } else {
        throw new Error(data.message || 'Error desconocido');
      }
    } catch {
      status.textContent = `Ha ocurrido un error al enviar el formulario. Llámanos directamente al ${form.dataset.phoneDisplay ?? ''} y te atendemos al momento.`;
      status.className = 'text-sm text-center text-red-400 font-semibold';
    } finally {
      status.classList.remove('hidden');
      if (submitBtn.disabled) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Enviar solicitud de presupuesto';
      }
    }
  });
</script>
