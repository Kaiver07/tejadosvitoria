---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import BlogCard from '../../components/BlogCard.astro';
import { site } from '../../config/site.config';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const title = `Blog de Tejados | ${site.name}`;
const description = `Consejos prácticos sobre reparación, mantenimiento y precios de tejados en Vitoria-Gasteiz y Álava, escritos por especialistas con ${site.yearsExperience} años de experiencia.`;
---

<PageLayout title={title} description={description}>

  <div class="bg-gray-50 border-b border-gray-200">
    <div class="section-container py-3">
      <Breadcrumb items={[{ name: 'Blog', href: '/blog/' }]} />
    </div>
  </div>

  <section class="bg-brand-primary text-white">
    <div class="section-container py-12">
      <h1 class="text-3xl sm:text-4xl font-bold mb-4">Blog de Tejados</h1>
      <p class="text-gray-300 text-lg max-w-xl">
        Consejos prácticos sobre goteras, humedades, retejados y mantenimiento de cubiertas, escritos por especialistas que llevan {site.yearsExperience} años trabajando en Vitoria-Gasteiz y la comarca de Álava.
      </p>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="section-container">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post) => (
          <BlogCard
            slug={post.id}
            title={post.data.title}
            description={post.data.description}
            publishDate={post.data.publishDate}
            image={post.data.image}
          />
        ))}
      </div>

      <div class="mt-12 bg-gray-50 rounded-2xl p-8 text-center border border-gray-200">
        <h2 class="text-2xl font-bold text-brand-primary mb-3">
          ¿Necesitas ayuda con tu tejado ahora mismo?
        </h2>
        <p class="text-gray-600 mb-6">
          Si tu problema no puede esperar, llámanos directamente y te damos presupuesto gratuito en menos de 24 horas.
        </p>
        <a href={`tel:${site.phone}`} class="btn-cta text-lg px-8 py-4">
          ☎ {site.phoneDisplay}
        </a>
      </div>
    </div>
  </section>

</PageLayout>
