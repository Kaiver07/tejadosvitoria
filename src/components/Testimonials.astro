---
import { site } from '../config/site.config';
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
  {site.testimonials.map((t) => (
    <blockquote class="bg-white rounded-xl border border-gray-200 p-6 flex flex-col gap-4">
      <!-- Estrellas -->
      <div class="flex gap-0.5" aria-label={`Valoración: ${t.rating} de 5 estrellas`}>
        {Array.from({ length: t.rating }).map(() => (
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        ))}
      </div>
      <p class="text-gray-700 leading-relaxed flex-1">"{t.text}"</p>
      <footer class="flex justify-between items-end text-sm">
        <cite class="not-italic font-semibold text-brand-primary">{t.name}</cite>
        <span class="text-gray-400">{t.location}</span>
      </footer>
    </blockquote>
  ))}
</div>
