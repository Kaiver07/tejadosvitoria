---
import { site } from '../config/site.config';
---

<header class="sticky top-0 z-40 bg-brand-primary shadow-lg">
  <div class="section-container">
    <div class="flex items-center justify-between h-16 lg:h-20">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2" aria-label={`${site.name} - inicio`}>
        <span class="text-white font-bold text-lg lg:text-xl leading-tight">
          {site.name}
        </span>
      </a>

      <!-- Desktop: teléfono + CTA -->
      <div class="hidden md:flex items-center gap-4">
        <a
          href={`tel:${site.phone}`}
          class="flex items-center gap-2 text-white font-semibold text-lg hover:text-brand-accent transition-colors"
          aria-label={`Llamar a ${site.phoneDisplay}`}
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/>
          </svg>
          {site.phoneDisplay}
        </a>
        <a href="#contacto" class="btn-cta text-sm px-5 py-2.5">
          Presupuesto Gratis
        </a>
      </div>

      <!-- Mobile: teléfono visible -->
      <a
        href={`tel:${site.phone}`}
        class="md:hidden flex items-center gap-1.5 text-white font-bold"
        aria-label={`Llamar a ${site.phoneDisplay}`}
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/>
        </svg>
        {site.phoneDisplay}
      </a>

    </div>
  </div>
</header>
