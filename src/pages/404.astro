---
import PageLayout from '../layouts/PageLayout.astro';
import { site } from '../config/site.config';

const title = `Página no encontrada | ${site.name}`;
const description = 'La página que buscas no existe o se ha movido. Vuelve al inicio o contáctanos directamente.';
---

<PageLayout title={title} description={description}>

  <section class="section-padding bg-white">
    <div class="section-container text-center max-w-xl mx-auto">
      <p class="text-brand-secondary font-extrabold text-6xl mb-4">404</p>
      <h1 class="text-2xl sm:text-3xl font-bold text-brand-primary mb-4">
        No hemos encontrado esta página
      </h1>
      <p class="text-gray-600 mb-8">
        Puede que el enlace esté roto o que la página se haya movido. Prueba a volver al inicio, revisa nuestros servicios o llámanos directamente si necesitas ayuda con tu tejado.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center mb-8">
        <a href="/" class="btn-cta py-3 px-6">Volver al inicio</a>
        <a href="/#servicios" class="btn-primary py-3 px-6">Ver servicios</a>
      </div>
      <p class="text-gray-500 text-sm">
        ¿Prefieres llamar? <a href={`tel:${site.phone}`} class="text-brand-secondary font-semibold hover:underline">{site.phoneDisplay}</a>
      </p>
    </div>
  </section>

</PageLayout>
