---
import { site } from '../config/site.config';
---

<ul class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
  {site.zones.map((zone) => (
    <li>
      <a
        href={`/zonas-donde-trabajamos/#${zone.slug}`}
        class="flex items-center gap-2 text-gray-700 hover:text-brand-secondary font-medium text-sm transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-secondary flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
        </svg>
        {zone.name}
      </a>
    </li>
  ))}
</ul>
