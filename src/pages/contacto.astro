---
import PageLayout from '../layouts/PageLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import ContactForm from '../components/ContactForm.astro';
import { site } from '../config/site.config';

const title = `Contacto | ${site.name}`;
const description = `Contacta con ${site.name}. ☎ ${site.phoneDisplay} · ${site.email} · ${site.hours}. Presupuesto gratuito sin compromiso.`;
---

<PageLayout title={title} description={description}>

  <div class="bg-gray-50 border-b border-gray-200">
    <div class="section-container py-3">
      <Breadcrumb items={[{ name: 'Contacto', href: '/contacto/' }]} />
    </div>
  </div>

  <section class="bg-brand-primary text-white">
    <div class="section-container py-12">
      <h1 class="text-3xl sm:text-4xl font-bold mb-3">Contacto</h1>
      <p class="text-gray-300 text-lg">Presupuesto gratuito sin compromiso. Respondemos en menos de 24 horas.</p>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="section-container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">

        <!-- Info de contacto -->
        <div>
          <h2 class="text-2xl font-bold text-brand-primary mb-6">Cómo Contactarnos</h2>

          <div class="space-y-5">
            <div class="flex gap-4">
              <div class="w-10 h-10 bg-brand-secondary/10 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-secondary" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-gray-800">Teléfono</p>
                <a href={`tel:${site.phone}`} class="text-brand-secondary font-bold text-xl hover:underline">
                  {site.phoneDisplay}
                </a>
                <p class="text-gray-500 text-sm mt-0.5">Urgencias 24h · 7 días a la semana</p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="w-10 h-10 bg-brand-secondary/10 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-gray-800">Email</p>
                <a href={`mailto:${site.email}`} class="text-brand-secondary hover:underline">
                  {site.email}
                </a>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="w-10 h-10 bg-brand-secondary/10 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-gray-800">Dirección</p>
                <address class="not-italic text-gray-600 text-sm">
                  {site.address.street}<br />
                  {site.address.postalCode} {site.address.city}<br />
                  {site.address.province}
                </address>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="w-10 h-10 bg-brand-secondary/10 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-gray-800">Horario</p>
                <p class="text-gray-600">{site.hours}</p>
              </div>
            </div>
          </div>

          <!-- Mapa embed simple (sin API de Google Maps) -->
          <div class="mt-8 rounded-xl overflow-hidden border border-gray-200 aspect-video">
            <iframe
              title={`Localización de ${site.name} en ${site.address.city}`}
              src={`https://www.openstreetmap.org/export/embed.html?bbox=-2.7&lat=42.8467&zoom=13&layers=M&marker=${site.geo.lat},${site.geo.lng}`}
              width="100%"
              height="100%"
              loading="lazy"
              style="border: 0;"
            ></iframe>
          </div>
        </div>

        <!-- Formulario -->
        <div>
          <ContactForm title="Solicitar Presupuesto" subtitle="Rellena el formulario y te llamamos en menos de 24 horas." />
        </div>

      </div>
    </div>
  </section>

</PageLayout>
