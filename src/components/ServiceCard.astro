---
interface Props {
  name: string;
  shortDesc: string;
  slug: string;
}
const { name, shortDesc, slug } = Astro.props;
---

<article class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-lg hover:border-brand-secondary transition-all duration-200 flex flex-col">
  <!-- Icono genérico de tejado -->
  <div class="w-10 h-10 bg-brand-secondary/10 rounded-lg flex items-center justify-center mb-4 flex-shrink-0">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9" />
    </svg>
  </div>
  <h3 class="font-bold text-brand-primary text-lg mb-2">{name}</h3>
  <p class="text-gray-600 text-sm leading-relaxed flex-1 mb-4">{shortDesc}</p>
  <a
    href={`/servicio/${slug}/`}
    class="text-brand-secondary font-semibold text-sm hover:underline inline-flex items-center gap-1"
    aria-label={`Ver servicio: ${name}`}
  >
    Ver servicio
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
  </a>
</article>
