---
import { site } from '../config/site.config';
---

<!-- Banner de consentimiento de cookies -->
<div
  id="cookie-banner"
  class="fixed bottom-0 left-0 right-0 z-50 bg-gray-900 border-t-2 border-brand-secondary shadow-2xl hidden"
  role="dialog"
  aria-label="Aviso de cookies"
  aria-live="polite"
>
  <div class="section-container py-4">
    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">

      <!-- Texto -->
      <div class="flex-1 text-sm text-gray-300 leading-relaxed pr-4">
        <span class="font-semibold text-white">🍪 Esta página web utiliza cookies técnicas</span>
        {' '}con la finalidad de optimizar el sitio web y asegurar su correcto funcionamiento.
        No recaba ni cede datos de carácter personal. Para más información accede a nuestra{' '}
        <a
          href="/politica-de-cookies/"
          class="text-brand-accent underline hover:text-white transition-colors"
        >
          Política de Cookies
        </a>.
      </div>

      <!-- Botones -->
      <div class="flex items-center gap-2 flex-shrink-0">
        <button
          id="cookie-reject"
          class="border border-gray-500 text-gray-300 hover:border-gray-300 hover:text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors"
        >
          Rechazar
        </button>
        <button
          id="cookie-accept"
          class="bg-brand-secondary hover:bg-brand-secondary-dark text-white text-sm font-bold px-5 py-2 rounded-lg transition-colors"
        >
          Aceptar
        </button>
        <button
          id="cookie-close"
          class="text-gray-500 hover:text-white transition-colors ml-1 p-1"
          aria-label="Cerrar aviso de cookies"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

    </div>
  </div>
</div>

<script>
  const STORAGE_KEY = 'cookie_consent';
  const banner = document.getElementById('cookie-banner');

  function updateBannerOffset() {
    const h = banner && !banner.classList.contains('hidden') ? banner.offsetHeight : 0;
    document.documentElement.style.setProperty('--cookie-banner-h', `${h}px`);
  }

  function hideBanner() {
    banner?.classList.add('hidden');
    updateBannerOffset();
  }

  function showBanner() {
    banner?.classList.remove('hidden');
    updateBannerOffset();
  }

  // Mostrar solo si no hay decisión previa
  if (!localStorage.getItem(STORAGE_KEY)) {
    showBanner();
  }

  window.addEventListener('resize', updateBannerOffset);

  document.getElementById('cookie-accept')?.addEventListener('click', () => {
    localStorage.setItem(STORAGE_KEY, 'accepted');
    window.loadGoogleAnalytics?.();
    hideBanner();
  });

  document.getElementById('cookie-reject')?.addEventListener('click', () => {
    localStorage.setItem(STORAGE_KEY, 'rejected');
    hideBanner();
  });

  document.getElementById('cookie-close')?.addEventListener('click', () => {
    // Cerrar sin guardar → vuelve a aparecer en la próxima visita
    hideBanner();
  });
</script>
