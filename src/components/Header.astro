---
import { site } from '../config/site.config';
import WeatherWidget from './WeatherWidget.astro';

const navLinks = [
  { label: 'Inicio',    href: '/' },
  { label: 'Servicios', href: '/#servicios' },
  { label: 'Zonas',     href: '/zonas-donde-trabajamos/' },
  { label: 'Contacto',  href: '/contacto/' },
];
---

<header class="sticky top-0 z-40 bg-brand-primary shadow-lg">
  <div class="section-container">
    <div class="flex items-center justify-between h-16 lg:h-20 gap-4">

      <!-- Logo -->
      <a href="/" class="flex-shrink-0 flex items-center gap-2.5" aria-label={`${site.name} - inicio`}>
        <!-- Icono tejado SVG -->
        <div class="w-9 h-9 bg-brand-secondary rounded-lg flex items-center justify-center flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9" />
          </svg>
        </div>
        <div class="hidden sm:block leading-tight">
          <span class="text-white font-bold text-base block">{site.name}</span>
          <span class="text-gray-400 text-xs uppercase tracking-wide">Vitoria-Gasteiz</span>
        </div>
      </a>

      <!-- Nav desktop -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Navegación principal">
        {navLinks.map((l) => (
          <a
            href={l.href}
            class="text-gray-300 hover:text-white text-sm font-medium px-3 py-2 rounded-lg hover:bg-white/10 transition-colors"
          >
            {l.label}
          </a>
        ))}
      </nav>

      <!-- Tiempo en Vitoria + teléfono -->
      <div class="flex items-center gap-3 flex-shrink-0">
        <WeatherWidget />
        <!-- Botón teléfono -->
        <a
          href={`tel:${site.phone}`}
          class="flex items-center gap-2 bg-brand-secondary hover:bg-brand-secondary-dark text-white font-bold px-4 py-2.5 rounded-lg transition-colors text-sm lg:text-base"
          aria-label={`Llamar a ${site.phoneDisplay}`}
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/>
          </svg>
          <span class="hidden sm:inline">{site.phoneDisplay}</span>
          <span class="sm:hidden">Llamar</span>
        </a>

        <!-- Botón menú móvil -->
        <button
          id="menu-toggle"
          type="button"
          class="lg:hidden flex items-center justify-center w-10 h-10 -mr-2 rounded-lg hover:bg-white/10 transition-colors flex-shrink-0"
          aria-label="Abrir menú"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg id="menu-icon-open" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="menu-icon-close" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

    </div>
  </div>

  <!-- Panel menú móvil -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden fixed inset-x-0 top-16 bottom-0 z-40 bg-brand-primary overflow-y-auto"
  >
    <nav class="section-container py-4 flex flex-col" aria-label="Navegación móvil">
      {navLinks.map((l) => (
        <a
          href={l.href}
          class="text-white text-lg font-semibold px-2 py-4 border-b border-white/10 active:bg-white/10 transition-colors"
        >
          {l.label}
        </a>
      ))}
      <a href={`tel:${site.phone}`} class="btn-cta text-lg py-4 mt-6 justify-center">
        ☎ Llamar: {site.phoneDisplay}
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');
  const floatingCallBtn = document.getElementById('floating-call-btn');

  function openMenu() {
    menu?.classList.remove('hidden');
    toggle?.setAttribute('aria-expanded', 'true');
    iconOpen?.classList.add('hidden');
    iconClose?.classList.remove('hidden');
    floatingCallBtn?.classList.add('hidden');
    document.body.classList.add('overflow-hidden');
  }

  function closeMenu() {
    menu?.classList.add('hidden');
    toggle?.setAttribute('aria-expanded', 'false');
    iconOpen?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
    floatingCallBtn?.classList.remove('hidden');
    document.body.classList.remove('overflow-hidden');
  }

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    isOpen ? closeMenu() : openMenu();
  });

  menu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeMenu));

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth >= 1024) closeMenu();
  });
</script>
