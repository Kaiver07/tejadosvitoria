---
import PageLayout from '../layouts/PageLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ContactForm from '../components/ContactForm.astro';
import Testimonials from '../components/Testimonials.astro';
import ZonesList from '../components/ZonesList.astro';
import { site } from '../config/site.config';
---

<PageLayout
  title={site.defaultTitle}
  description={site.defaultDescription}
>

  <!-- ======================== HERO ======================== -->
  <section class="relative bg-brand-primary text-white overflow-hidden min-h-[580px] flex items-center">
    <!-- Imagen de fondo con overlay -->
    <div
      class="absolute inset-0 bg-cover bg-center"
      style="background-image: url('/images/reparacion-tejados-vitoria-new.webp');"
      aria-hidden="true"
    ></div>
    <div class="absolute inset-0 bg-brand-primary/82" aria-hidden="true"></div>

    <div class="relative z-10 section-container w-full py-14 lg:py-20">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">

        <!-- Columna izquierda: texto + CTAs -->
        <div>
          <!-- Badge urgencia -->
          <div class="inline-flex items-center gap-2 bg-brand-secondary/20 border border-brand-secondary/50 text-brand-accent text-xs font-bold uppercase tracking-widest px-4 py-1.5 rounded-full mb-5">
            <span class="w-2 h-2 rounded-full bg-brand-secondary animate-pulse"></span>
            Urgencias 24h · 7 días
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-[1.1] mb-5">
            Tejados<br />
            <span class="text-brand-secondary">Vitoria-Gasteiz</span><br />
            <span class="text-3xl sm:text-4xl font-bold text-gray-200">Reparación Express</span>
          </h1>

          <p class="text-lg text-gray-300 mb-8 max-w-lg">
            Reparamos y renovamos tejados en Vitoria y Álava.
            <strong class="text-white">Presupuesto gratis</strong> · Garantía por escrito ·
            <strong class="text-brand-accent">{site.yearsExperience} años de experiencia</strong>.
          </p>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-3 mb-7">
            <a href={`tel:${site.phone}`} class="btn-cta text-lg py-4 px-7">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/>
              </svg>
              Llamar: {site.phoneDisplay}
            </a>
            <a href="#contacto" class="btn-outline-white text-lg py-4 px-7">
              Presupuesto Gratis
            </a>
          </div>

          <!-- Trust badges -->
          <div class="flex flex-wrap gap-x-5 gap-y-2 text-sm text-gray-300">
            <span class="flex items-center gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              Respuesta en 24h
            </span>
            <span class="flex items-center gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
              Garantía por escrito
            </span>
            <span class="flex items-center gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>
              18 años de experiencia
            </span>
          </div>
        </div>

        <!-- Columna derecha: 3 tarjetas de servicio rápido -->
        <div class="flex flex-col gap-3">
          {[
            {
              icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9" />`,
              color: 'bg-brand-secondary',
              title: 'Reparación de Tejados',
              sub: 'Goteras · Tejas rotas · Filtraciones',
              href: '/servicio/reparacion-de-tejados/',
            },
            {
              icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />`,
              color: 'bg-blue-600',
              title: 'Impermeabilización',
              sub: 'Cubiertas planas · Azoteas · EPDM',
              href: '/servicio/impermeabilizacion-de-cubiertas/',
            },
            {
              icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />`,
              color: 'bg-purple-600',
              title: 'Urgencias 24 Horas',
              sub: 'Noches · Festivos · Fines de semana',
              href: '#contacto',
            },
          ].map((card) => (
            <a
              href={card.href}
              class="group flex items-center gap-4 bg-white/10 hover:bg-white/20 backdrop-blur-sm border border-white/20 rounded-xl p-4 transition-all duration-200"
            >
              <div class={`w-11 h-11 ${card.color} rounded-lg flex items-center justify-center flex-shrink-0`}>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true" set:html={card.icon} />
              </div>
              <div class="flex-1 min-w-0">
                <p class="font-bold text-white text-base leading-tight">{card.title}</p>
                <p class="text-gray-300 text-sm mt-0.5">{card.sub}</p>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gray-400 group-hover:text-white group-hover:translate-x-1 transition-all flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- ======================== INTRO ======================== -->
  <section class="section-padding bg-white">
    <div class="section-container">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-2xl lg:text-3xl font-bold text-brand-primary mb-6">
          Especialistas en Tejados y Cubiertas en Vitoria-Gasteiz
        </h2>
        <div class="text-gray-600 leading-relaxed space-y-4 text-left">
          <p>
            En <strong>Tejados Vitoria Express</strong> llevamos más de {site.yearsExperience} años reparando, instalando y manteniendo tejados en Vitoria-Gasteiz y toda la comarca de Álava. Sabemos que un tejado dañado no espera: las lluvias del otoño vasco, las heladas de enero y los vientos del sur pueden convertir una pequeña gotera en un problema estructural si no se actúa a tiempo.
          </p>
          <p>
            Ofrecemos presupuesto gratuito y sin compromiso, con diagnóstico fotográfico sobre el terreno. Nuestros técnicos trabajan con materiales homologados para el clima atlántico-continental de Vitoria —teja cerámica antihielo, impermeabilizantes de larga duración, canalones de aluminio— y aplicamos <strong>garantía por escrito</strong> en toda reparación o instalación.
          </p>
          <p>
            Atendemos desde pequeñas reparaciones puntuales hasta proyectos completos de tejado nuevo, impermeabilización de cubiertas planas, aislamiento térmico y rehabilitación de fachadas. Trabajamos en viviendas particulares, comunidades de propietarios, locales comerciales y naves industriales en Vitoria y los 18 municipios de Álava en los que prestamos servicio.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ======================== SERVICIOS ======================== -->
  <section id="servicios" class="section-padding bg-gray-50">
    <div class="section-container">
      <div class="text-center mb-10">
        <h2 class="text-2xl lg:text-3xl font-bold text-brand-primary mb-3">
          Nuestros Servicios de Tejados en Vitoria-Gasteiz
        </h2>
        <p class="text-gray-600 max-w-xl mx-auto">
          Soluciones completas para cualquier tipo de cubierta, desde una reparación urgente hasta la instalación de un tejado nuevo.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
        {site.services.map((s) => (
          <ServiceCard name={s.name} shortDesc={s.shortDesc} slug={s.slug} />
        ))}
      </div>
    </div>
  </section>

  <!-- ======================== FORMULARIO ======================== -->
  <section class="section-padding bg-white">
    <div class="section-container">
      <div class="max-w-2xl mx-auto">
        <ContactForm />
      </div>
    </div>
  </section>

  <!-- ======================== POR QUÉ ELEGIRNOS ======================== -->
  <section class="section-padding bg-gray-50">
    <div class="section-container">
      <div class="text-center mb-10">
        <h2 class="text-2xl lg:text-3xl font-bold text-brand-primary mb-3">
          ¿Por Qué Elegir Tejados Vitoria Express?
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { icon: '🏆', title: `${site.yearsExperience} Años de Experiencia`, desc: 'Llevamos casi dos décadas trabajando en tejados en Vitoria-Gasteiz y la comarca de Álava. Conocemos el clima, los materiales y los problemas típicos de la zona.' },
          { icon: '⚡', title: 'Respuesta en 24 Horas', desc: 'Atendemos urgencias cualquier día de la semana, incluyendo fines de semana y festivos. Si llueve esta noche, mañana estamos allí.' },
          { icon: '📋', title: 'Presupuesto Gratuito', desc: 'Sin compromiso, con diagnóstico fotográfico y desglose detallado antes de empezar. Sabes exactamente qué se va a hacer y cuánto va a costar.' },
          { icon: '✅', title: 'Garantía por Escrito', desc: 'Todos nuestros trabajos incluyen garantía de mano de obra de 2 años y la garantía del fabricante en materiales, que puede alcanzar los 15 años.' },
          { icon: '🔧', title: 'Materiales de Primera', desc: 'Solo trabajamos con proveedores certificados y materiales homologados para el clima de Álava. Sin soluciones temporales ni materiales de baja calidad.' },
          { icon: '🏘️', title: 'Servicio en Toda Álava', desc: `Cubrimos Vitoria-Gasteiz y ${site.zones.length} municipios de la comarca. El desplazamiento va incluido en el presupuesto sin coste adicional.` },
        ].map((item) => (
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <div class="text-3xl mb-3" aria-hidden="true">{item.icon}</div>
            <h3 class="font-bold text-brand-primary mb-2">{item.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ======================== URGENCIAS 24H ======================== -->
  <section class="bg-brand-secondary">
    <div class="section-container py-12">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6 text-white text-center md:text-left">
        <div>
          <h2 class="text-2xl lg:text-3xl font-bold mb-2">
            ¿Gotera Urgente? Tejado Dañado por la Tormenta?
          </h2>
          <p class="text-white/90 text-lg">
            Servicio de emergencias 7 días a la semana. Atendemos en el menor tiempo posible.
          </p>
        </div>
        <a
          href={`tel:${site.phone}`}
          class="flex-shrink-0 bg-white text-brand-secondary font-bold text-xl px-8 py-5 rounded-xl hover:bg-gray-100 transition-colors shadow-lg"
        >
          ☎ {site.phoneDisplay}
        </a>
      </div>
    </div>
  </section>

  <!-- ======================== ZONAS ======================== -->
  <section class="section-padding bg-gray-50">
    <div class="section-container">
      <div class="text-center mb-8">
        <h2 class="text-2xl lg:text-3xl font-bold text-brand-primary mb-3">
          Zonas de Trabajo en Álava
        </h2>
        <p class="text-gray-600 max-w-xl mx-auto">
          Prestamos servicio de reparación e instalación de tejados en Vitoria-Gasteiz y los siguientes municipios de la comarca:
        </p>
      </div>
      <ZonesList />
      <p class="text-center mt-6">
        <a href="/zonas-donde-trabajamos/" class="text-brand-secondary font-semibold hover:underline">
          Ver descripción completa de cada zona →
        </a>
      </p>
    </div>
  </section>

  <!-- ======================== GALERÍA ======================== -->
  <section class="section-padding bg-gray-50">
    <div class="section-container">
      <div class="text-center mb-8">
        <h2 class="text-2xl lg:text-3xl font-bold text-brand-primary mb-3">
          Algunos de Nuestros Trabajos
        </h2>
        <p class="text-gray-600 max-w-xl mx-auto">
          Tejados reparados, instalados e impermeabilizados en Vitoria-Gasteiz y la comarca de Álava.
        </p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 lg:gap-4">
        {[
          { src: '/images/trabajos/instalacion-tejado-nuevo-01.webp', alt: 'Instalación de tejado nuevo con teja cerámica' },
          { src: '/images/trabajos/impermeabilizacion-cubierta-plana-01.webp', alt: 'Impermeabilización de cubierta plana' },
          { src: '/images/trabajos/instalacion-canalon-01.webp', alt: 'Instalación de canalón de aluminio' },
          { src: '/images/trabajos/instalacion-claraboya-velux-01.webp', alt: 'Instalación de claraboya tipo Velux' },
          { src: '/images/trabajos/rehabilitacion-fachada-antes-despues-01.webp', alt: 'Rehabilitación de fachada, antes y después' },
          { src: '/images/trabajos/cubierta-panel-sandwich-01.webp', alt: 'Instalación de cubierta con panel sándwich' },
          { src: '/images/trabajos/cubierta-industrial-nave-01.webp', alt: 'Cubierta industrial en nave' },
        ].map((img) => (
          <div class="overflow-hidden rounded-xl aspect-video bg-gray-200">
            <img
              src={img.src}
              alt={img.alt}
              width="600"
              height="400"
              loading="lazy"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ======================== TESTIMONIOS ======================== -->
  <section class="section-padding bg-white">
    <div class="section-container">
      <div class="text-center mb-8">
        <h2 class="text-2xl lg:text-3xl font-bold text-brand-primary mb-3">
          Lo Que Dicen Nuestros Clientes
        </h2>
        <p class="text-gray-600">Opiniones reales de clientes en Vitoria-Gasteiz y la comarca de Álava.</p>
      </div>
      <Testimonials />
    </div>
  </section>

  <!-- ======================== CTA FINAL ======================== -->
  <section class="section-padding bg-brand-primary text-white">
    <div class="section-container text-center">
      <h2 class="text-2xl lg:text-3xl font-bold mb-4">
        ¿Necesitas Reparar o Instalar un Tejado en Vitoria-Gasteiz?
      </h2>
      <p class="text-gray-300 text-lg mb-8 max-w-xl mx-auto">
        Llámanos o escríbenos ahora. Presupuesto gratuito, sin compromiso y en menos de 24 horas.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={`tel:${site.phone}`} class="btn-cta text-xl py-5 px-10">
          ☎ {site.phoneDisplay}
        </a>
        <a href="#contacto" class="btn-outline-white text-xl py-5 px-10">
          Escribir mensaje
        </a>
      </div>
      <p class="mt-4 text-sm text-gray-400">{site.hours}</p>
    </div>
  </section>

</PageLayout>
