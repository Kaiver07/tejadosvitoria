---
import { site } from '../config/site.config';

interface BreadcrumbItem {
  name: string;
  href: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;

const schemaItems = [
  { '@type': 'ListItem', position: 1, name: 'Inicio', item: site.url + '/' },
  ...items.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 2,
    name: item.name,
    item: site.url + item.href,
  })),
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: schemaItems,
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />

<nav aria-label="Navegación de migas de pan" class="text-sm text-gray-500">
  <ol class="flex flex-wrap items-center gap-1.5">
    <li>
      <a href="/" class="hover:text-brand-secondary transition-colors">Inicio</a>
    </li>
    {items.map((item, i) => (
      <>
        <li aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </li>
        <li>
          {i === items.length - 1 ? (
            <span class="text-gray-800 font-medium" aria-current="page">{item.name}</span>
          ) : (
            <a href={item.href} class="hover:text-brand-secondary transition-colors">{item.name}</a>
          )}
        </li>
      </>
    ))}
  </ol>
</nav>
